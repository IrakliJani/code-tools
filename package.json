{
  "name": "code-tools",
  "version": "0.1.0",
  "description": "Compress many Vercel AI SDK tools into two local sandbox tools: bash and code.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "test": "vitest run",
    "example:basic": "tsx examples/weather-email.ts",
    "example:llm": "tsx examples/llm-weather-email.ts",
    "example:mcp:github": "tsx examples/mcp-github.ts",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/provider-utils": "^4.0.27",
    "isolated-vm": "^6.0.2",
    "just-bash": "^3.0.1",
    "oxc-transform": "^0.134.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/mcp": "^1.0.46",
    "@ai-sdk/openai": "^3.0.67",
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260604.1",
    "ai": "^6.0.196",
    "boxen": "^8.0.1",
    "cli-highlight": "^2.1.11",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
